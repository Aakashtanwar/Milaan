# Milaan environment (Spec §12/§13). Copy to `.env` for local dev.
# Never commit real secrets — `.env` is gitignored.

EXPO_PUBLIC_ENV=local

# Local Supabase stack (values from `supabase status`).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Per-service provider mode: mock | live. Phase 0 runs everything in mock,
# so the whole app works with zero paid API calls.
EXPO_PUBLIC_PROVIDER_IDENTITY=mock
EXPO_PUBLIC_PROVIDER_BIOMETRIC=mock
EXPO_PUBLIC_PROVIDER_MODERATION=mock
EXPO_PUBLIC_PROVIDER_CHAT=mock
